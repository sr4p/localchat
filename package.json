{
  "name": "lfm2-webgpu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:up": "docker compose -f docker/docker-compose.yml up -d",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "db:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "db:reset": "docker compose -f docker/docker-compose.yml down -v && docker compose -f docker/docker-compose.yml up -d",
    "db:migrate-legacy": "sh -c 'docker compose -f docker/docker-compose.yml exec -T postgres psql -U \"${DB_USER:-postgres}\" -d \"${DB_NAME:-chat_ai}\" -v ON_ERROR_STOP=1' < docker/postgres/migrate_legacy_typeorm_columns.sql",
    "test:db:up": "docker compose -f test/docker-compose.yml up -d",
    "test:db:down": "docker compose -f test/docker-compose.yml down -v",
    "test:db:logs": "docker compose -f test/docker-compose.yml logs -f",
    "test:db": "bun run test:db:up && sleep 5 && bun test test/db.spec.ts && bun run test:db:down",
    "typeorm": "typeorm-ts-node-esm",
    "schema:sync": "bun run src/db/schema-sync.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0-next.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "elysia": "^1.4.28",
    "lucide-react": "^0.563.0",
    "next": "^16.2.2",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "reflect-metadata": "^0.2.2",
    "streamdown": "^2.2.0",
    "tailwindcss": "^4.1.18",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  }
}
